msgid "`compute_1_to_1`, `compute_1_to_0`, `compute_1_to_n`, `compute_n_to_1`, `compute_2_to_1`"
msgstr "`compute_1_to_1`, `compute_1_to_0`, `compute_1_to_n`, `compute_n_to_1`, `compute_2_to_1`"

msgid "**No backward compatibility maintained** for these internal changes (closes [Issue #180](https://github.com/DataLab-Platform/DataLab/issues/180))"
msgstr "**Aucune compatibilité ascendante n'est maintenue** pour ces modifications internes (ceci clôture [Issue #180](https://github.com/DataLab-Platform/DataLab/issues/180))"

msgid "🛠️ Bug Fixes since version 0.20"
msgstr "🛠️ Correctifs depuis la version 0.20"

msgid "**Performance fixes:**"
msgstr "**Corrections de performances :**"

msgid "**Switching between images with many results**: Dramatic improvement (66s → <1ms) when navigating images with hundreds of shapes"
msgstr "**Passage entre images avec de nombreux résultats** : Amélioration spectaculaire (66s → <1ms) lors de la navigation entre des images avec des centaines de formes"

