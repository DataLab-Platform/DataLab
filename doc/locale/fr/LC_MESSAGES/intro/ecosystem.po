msgstr "Aucune — s'exécute dans le navigateur"

msgid "Python runtime"
msgstr "Environnement d'exécution Python"

msgid "System CPython"
msgstr "CPython du système"

msgid "Pyodide (CPython compiled to WebAssembly)"
