        {
            "label": "🧽 Ruff Formatter",
            "command": "${command:python.interpreterPath}",
            "args": [
                "scripts/run_with_env.py",
                "${command:python.interpreterPath}",
                "-m",
                "ruff",
                "format",
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "statusbar": {
                    "hide": true,
                },
            },
            "group": {
                "kind": "build",
                "isDefault": true,
            },
            "presentation": {
                "clear": true,
                "echo": true,
                "focus": false,
                "panel": "dedicated",
                "reveal": "always",
                "showReuseMessage": true,
            },
            "type": "shell",
        },
        {
